{
  // ===== SSE 模式：通过环境变量安全传递 Token（推荐）=====
  // Token 存储在用户级系统环境变量 FEISHU_MCP_TOKEN 中，不进版本控制，不弹框
  //
  // 【一次性设置步骤】
  // 1. 从「集成管理 → 📋 MCP配置」弹窗复制 Token
  // 2. 在终端执行设置命令（只需执行一次）：
  //    Windows PowerShell:
  //      [System.Environment]::SetEnvironmentVariable("FEISHU_MCP_TOKEN", "你的Token", "User")
  //    macOS / Linux (添加到 ~/.zshrc 或 ~/.bashrc):
  //      export FEISHU_MCP_TOKEN="你的Token"
  // 3. 重启 VS Code（环境变量需要重启才生效）
  // 4. 后续所有 Chat 会话自动无声连接，无弹框
  "servers": {
    "feishu-notifier": {
      "type": "sse",
      "url": "http://localhost:5173/api/mcp/sse?token=${env:FEISHU_MCP_TOKEN}"
    }
  }

  // ===== 备用方案：stdio 本地进程模式 =====
  // 如后端就在本机，可用此方案（无需 Token，更简单）
  //
  // "servers": {
  //   "feishu-notifier": {
  //     "type": "stdio",
  //     "command": "node",
  //     "args": ["${workspaceFolder}/mcp-server/index.js"]
  //   }
  // }
}