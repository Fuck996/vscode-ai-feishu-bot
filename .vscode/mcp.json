{
  // ===== 本地远端 SSE 测试模式（当前采用）=====
  // 通过前端 Vite dev proxy (localhost:5173) 连接
  // 不直接暴露后端 3001 端口，符合"只暴露前端"的架构约定
  // inputs 机制：VS Code 弹出密码框，Token 不明文存储
  "inputs": [
    {
      "type": "promptString",
      "id": "feishu_mcp_token",
      "description": "Feishu MCP Token（从集成管理页面「📋 MCP配置」按钮获取）",
      "password": true
    }
  ],
  "servers": {
    "feishu-notifier": {
      "type": "sse",
      "url": "http://localhost:5173/api/mcp/sse?token=${input:feishu_mcp_token}"
    }
  }

  // ===== 本地 stdio 模式（备用）=====
  // MCP 通过进程内通信，Token 自动从后端 /api/mcp/config 获取
  // "servers": {
  //   "feishu-notifier": {
  //     "type": "stdio",
  //     "command": "node",
  //     "args": ["${workspaceFolder}/mcp-server/index.js"]
  //   }
  // }

  // ===== 远端生产部署模式 =====
  // "url": "https://your-domain.com/api/mcp/sse?token=${input:feishu_mcp_token}"
}