# 飞书 AI 通知系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===== Docker Compose 配置 =====

# 前端外部访问端口（Docker Compose 用）
APP_PORT=45173

# ===== 后端配置 =====

# Node 环境
NODE_ENV=production

# 后端服务配置
PORT=3000
HOST=0.0.0.0

# 后端外部访问 URL（用于 MCP Server 生成 webhook endpoint）
# 开发: http://localhost:3000
# 生产: https://yourdomain.com 或通过反代访问的 URL
# Docker: http://localhost:${APP_PORT}
BACKEND_URL=http://localhost:45173

# 时区设置（默认北京时间）
TZ=Asia/Shanghai

# JWT 密钥（生产环境必须修改为强随机密钥，50+ 字符）
# 生成方式: openssl rand -base64 32
JWT_SECRET=dev-secret-key-change-in-production

# 飞书机器人 Webhook URL（可选，用于测试）
# 获取方式: 飞书群 → 群设置 → 群机器人 → 添加机器人 → 获取Webhook地址
FEISHU_WEBHOOK_URL=

# CORS 来源（逗号分隔，生产环境指定具体域名）
# 开发: http://localhost:5173,http://localhost:3000
# 生产/Docker: *
CORS_ORIGIN=*

# 数据库文件路径
DATABASE_PATH=./data/notifications.db

# 日志级别
LOG_LEVEL=info

# ===== Docker 部署特定 =====

# 是否启用 HTTPS（true 需要 SSL 证书）
ENABLE_HTTPS=false

# SSL 证书类型 (letsencrypt / self-signed / custom)
SSL_TYPE=self-signed

# 申请 Let's Encrypt 时使用的邮箱
LETSENCRYPT_EMAIL=your-email@example.com

# ===== NAS 部署特定 =====

# Synology 群晖 NAS 主机名或 IP
NAS_HOSTNAME=192.168.1.100

# 数据备份路径（群晖）
BACKUP_PATH=/volume1/backup/feishu-bot

# 容器资源限制
BACKEND_MEMORY_LIMIT=512m
BACKEND_CPU_LIMIT=0.5
FRONTEND_MEMORY_LIMIT=256m
FRONTEND_CPU_LIMIT=0.25
