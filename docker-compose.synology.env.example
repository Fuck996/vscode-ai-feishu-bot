# 群晖 Docker 部署 - .env 配置文件示例
# 用法：复制本文件内容到群晖的 /volume1/docker/feishu-bot/.env
#      然后修改以下变量值，最后运行：
#      docker compose -f docker-compose.synology.yml pull
#      docker compose -f docker-compose.synology.yml up -d

# ═══════════════════════════════════════════
# 【必填】飞书配置
# ═══════════════════════════════════════════
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/你的webhook-id

# ═══════════════════════════════════════════
# 【必填】JWT 认证密钥（应用内部使用，可任意字符串，建议 32 位以上）
# ═══════════════════════════════════════════
JWT_SECRET=your-strong-secret-key-min-32-chars-recommended

# ═══════════════════════════════════════════
# 【可选】前端访问端口（默认 8080）
# ═══════════════════════════════════════════
APP_PORT=8080
