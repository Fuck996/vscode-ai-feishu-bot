# 飞书配置
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# 服务器配置
PORT=3000
NODE_ENV=development
HOST=localhost

# 认证
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 数据库
DATABASE_PATH=./data/notifications.db

# 日志
LOG_LEVEL=info

# CORS（生产环境建议填写具体域名或群晖IP）
CORS_ORIGIN=*

# 后端公网 URL（用于 MCP 配置引导中显示正确地址）
# 本地：http://localhost:3000
# 群晖：http://你的NAS-IP:APP_PORT
BACKEND_URL=http://localhost:3000

# 前端对外端口（docker-compose 使用）
APP_PORT=8080

# 其他
MAX_RETRIES=3
REQUEST_TIMEOUT=30000

# ─── 群晖部署额外配置（docker-compose.synology.yml 使用）──
# GitHub 用户名（用于拉取 GHCR 镜像）
# GITHUB_OWNER=your-github-username
# 数据持久化目录（群晖绝对路径）
# DATA_PATH=/volume1/docker/feishu-bot/data
